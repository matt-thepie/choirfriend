# Server
PORT=3001
DATABASE_URL=postgres://choirfriend:choirfriend@localhost:5432/choirfriend
NODE_ENV=development

# Auth — choose one or more providers.
# Each provider is configured by its own AUTH_<NAME>_* vars and registered in src/auth/providers/.
# Example (generic OIDC — works for Google, Microsoft, Keycloak, sgmc-identity, etc):
AUTH_OIDC_ENABLED=true
AUTH_OIDC_LABEL="Sign in"
AUTH_OIDC_ISSUER=https://identity.example.com/
AUTH_OIDC_CLIENT_ID=choirfriend
AUTH_OIDC_CLIENT_SECRET=change-me
AUTH_OIDC_REDIRECT_URI=http://localhost:3001/auth/oidc/callback
AUTH_OIDC_SCOPES="openid profile email"

# Backblaze B2
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=choirfriend
B2_PUBLIC_BASE_URL=https://media.mgd.scot

# Cookie/session secret
SESSION_SECRET=change-me-to-a-long-random-string

# Client (Vite reads VITE_-prefixed vars)
VITE_API_BASE=http://localhost:3001
