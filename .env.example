# Server
PORT=3001
# Path relative to the server/ working directory when running `npm run dev`.
# In production the deploy script ensures ./data/ exists alongside the server.
DATABASE_FILE=./data/choirfriend.db
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Cookie/session secret — used for any cookies choirfriend signs itself.
# Not used to verify sgmc_token (that's done by identity's /verify endpoint).
SESSION_SECRET=change-me-to-a-long-random-string

# Dev-mode auth bypass — treats unauthenticated requests as a fake user so
# you can exercise authed endpoints without setting up cookie sharing with
# identity.sgmc.org.uk locally. Refuses to activate when NODE_ENV=production.
# Leave commented out to require real sign-in.
# DEV_AUTH_BYPASS=true
# DEV_AUTH_EMAIL=matt@choirfriend.local
# DEV_AUTH_NAME=Matt (dev)

# ---------------------------------------------------------------------------
# Auth providers — enable one or more.
# Each provider lives in server/src/auth/providers/ and is registered in
# server/src/auth/index.ts when its AUTH_<NAME>_ENABLED env var is "true".
# ---------------------------------------------------------------------------

# sgmc-identity (the SGMC-specific identity service).
# Login flow: redirect browser to PUBLIC_URL?redirect=<return URL>.
# The identity service sets `sgmc_token` cookie on .sgmc.org.uk, so any
# subdomain of sgmc.org.uk receives it for free.
# Verification: server-side POST to VERIFY_URL with the cookie value.
#   - Prod: VERIFY_URL=http://localhost:3050/verify (identity binds to localhost on the same VPS)
#   - Dev:  VERIFY_URL defaults to PUBLIC_URL + "/verify" if not set
AUTH_SGMC_IDENTITY_ENABLED=true
AUTH_SGMC_IDENTITY_LABEL="Sign in with SGMC"
AUTH_SGMC_IDENTITY_PUBLIC_URL=https://identity.sgmc.org.uk
# AUTH_SGMC_IDENTITY_VERIFY_URL=http://localhost:3050/verify

# Generic OIDC (Google, Microsoft, Keycloak, etc.) — stub, not yet implemented.
# AUTH_OIDC_ENABLED=true
# AUTH_OIDC_LABEL="Sign in"
# AUTH_OIDC_ISSUER=https://identity.example.com/
# AUTH_OIDC_CLIENT_ID=choirfriend
# AUTH_OIDC_CLIENT_SECRET=change-me
# AUTH_OIDC_REDIRECT_URI=http://localhost:3001/auth/oidc/callback
# AUTH_OIDC_SCOPES="openid profile email"

# ---------------------------------------------------------------------------
# Backblaze B2 storage — fronts media.mgd.scot
# ---------------------------------------------------------------------------
# choirfriend uses B2's S3-compatible API (AWS SDK v3 + sigv4 presigning).
# Bucket can be shared with other SGMC services; B2_KEY_PREFIX scopes
# choirfriend's writes/reads to a folder inside it (e.g. "music/").
#
# Where to find these:
#   B2_KEY_ID, B2_APPLICATION_KEY — Backblaze App Keys page. Use an "all
#       buckets" key or a per-bucket key restricted to your shared bucket.
#   B2_ENDPOINT, B2_REGION — Backblaze bucket detail page. Endpoint looks
#       like "https://s3.eu-central-003.backblazeb2.com"; region is the
#       middle bit ("eu-central-003").
#
# Public URL of an object: ${B2_PUBLIC_BASE_URL}/${B2_KEY_PREFIX}<key>
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003
B2_KEY_PREFIX=music/
B2_PUBLIC_BASE_URL=https://media.mgd.scot

# Client — Vite reads VITE_-prefixed vars only
VITE_API_BASE=http://localhost:3001
